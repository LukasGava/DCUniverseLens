@{
    ViewData["Title"] = "Identificar Personajes";
}

<section class="home-hero">
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="card shadow" style="width: 100%; max-width: 500px;">
            <div class="card-header text-center p-4">
                <h2 class="card-title m-0">Identificar Personajes</h2>
            </div>

            <div class="p-4">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show mt-3" role="alert">
                        @TempData["Message"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                    </div>
                }

                <form asp-action="IdentifyMultipleFaces" method="post" enctype="multipart/form-data" class="mt-3">
                    <div class="mb-3">
                        <label for="imageFile" class="form-label fw-bold">Selecciona una imagen con al menos un personaje</label>
                        <input class="form-control" type="file" id="imageFile" name="imageFile" accept="image/*" onchange="previewImage(event)">
                        <div class="form-text text-light">La imagen debe contener caras claramente visibles para una mejor detección.</div>
                    </div>

                    <div class="mb-3 text-center">
                        <img id="preview" src="#" alt="Vista previa" class="img-fluid rounded shadow" style="max-height: 300px; display: none;" />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg">Identificar</button>
                        <a asp-action="Index" class="btn btn-outline-light btn-lg">Volver al Inicio</a>
                    </div>
                </form>
            </div>


        </div>
    </div>
</section>

@section Scripts {
    <script>
        function previewImage(event) {
            const preview = document.getElementById('preview');
            const file = event.target.files[0];

            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';
            }
        }
    </script>
}