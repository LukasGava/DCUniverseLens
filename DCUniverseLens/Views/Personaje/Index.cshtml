@{
    ViewData["Title"] = "Reconocimiento de Personajes";
}

<section class="home-hero">
    <div class="container mt-5 d-flex justify-content-center align-items-center" style="min-height: 65vh;">
        <div class="row align-items-center">
            <div class="col-md-6 mb-4 text-center text-md-start">
                <h1 class="display-4">Reconocimiento de Personajes</h1>
                <p class="lead">Sube una imagen de uno o varios personajes del DCEU y nuestro modelo de IA te dirá quiénes son.</p>
                <a asp-action="VerPersonajes" class="btn btn-success footer-btn">Ver Personajes</a>
            </div>

            <div class="col-md-6 d-flex justify-content-center">
                <div class="card shadow" style="width: 100%; max-width: 450px;">
                    <div class="card-header text-center p-4">
                        <h5 class="card-title">Identificar Personajes</h5>
                    </div>
                    <div class="card-body text-center">
                        <p class="card-text">Sube una imagen con varios personajes para identificarlos a todos</p>
                        <a asp-action="UploadMultiple" class="btn btn-success">Subir Imagen</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>